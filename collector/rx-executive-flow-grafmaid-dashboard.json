      "id": 1,
      "options": {
        "content": "flowchart LR\n  classDef good fill:#2e7d32,color:#fff,stroke:#1b5e20,stroke-width:2px\n  classDef warn fill:#f9a825,color:#141414,stroke:#f57f17,stroke-width:2px\n  classDef bad fill:#c62828,color:#fff,stroke:#8e0000,stroke-width:2px\n  classDef core fill:#263238,color:#fff,stroke:#90a4ae,stroke-width:1px\n  classDef data fill:#1565c0,color:#fff,stroke:#0d47a1,stroke-width:1px\n  classDef obs fill:#6a1b9a,color:#fff,stroke:#4a148c,stroke-width:1px\n\n  operator[Operator / rx-ui<br/>${__data.ui:display}]:::core\n  load[Loadgen<br/>${__data.loadgen:display}]:::core\n  api[API Gateway<br/>${__data.api:display}]:::core\n  commands[(RabbitMQ commands<br/>publish ${__data.commandPublish:display} / consume ${__data.commandConsume:display})]:::data\n  worker[Legacy Sync Worker<br/>${__data.worker:display}]:::core\n  sql[(SQL transactional model)]:::data\n  events[(RabbitMQ events<br/>publish ${__data.eventPublish:display} / consume ${__data.eventConsume:display})]:::data\n  projection[Read Model Projection<br/>${__data.projection:display}]:::core\n  redis[(Redis read model)]:::data\n  otel[OpenTelemetry Collector]:::obs\n  grafana[Grafana executive view]:::obs\n\n  operator --> api\n  load --> api\n  api --> commands\n  commands --> worker\n  worker --> sql\n  worker --> events\n  events --> projection\n  projection --> redis\n  api --> redis\n\n  operator -. telemetry .-> otel\n  load -. telemetry .-> otel\n  api -. telemetry .-> otel\n  worker -. telemetry .-> otel\n  projection -. telemetry .-> otel\n  otel --> grafana\n\n  style api fill:${__data.api:color},color:#fff\n  style worker fill:${__data.worker:color},color:#fff\n  style projection fill:${__data.projection:color},color:#fff\n  style operator fill:${__data.ui:color},color:#fff\n  style load fill:${__data.loadgen:color},color:#fff",
        "escapeSpecialChars": false,
        "maxDataRows": 100
      },
      "pluginVersion": "11.1.4",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by(component) (rx_component_health_percent{component=\"api-gateway\"})",
          "legendFormat": "api",
          "range": true,
          "refId": "api"
        },
        {
          "editorMode": "code",
          "expr": "max by(component) (rx_component_health_percent{component=\"legacy-sync-worker\"})",
          "legendFormat": "worker",
          "range": true,
          "refId": "worker"
        },
        {
          "editorMode": "code",
          "expr": "max by(component) (rx_component_health_percent{component=\"read-model-projection\"})",
          "legendFormat": "projection",
          "range": true,
          "refId": "projection"
        },
        {
          "editorMode": "code",
          "expr": "max by(component) (rx_component_health_percent{component=\"rx-ui\"})",
          "legendFormat": "ui",
          "range": true,
          "refId": "ui"
        },
        {
          "editorMode": "code",
          "expr": "max by(component) (rx_component_health_percent{component=\"rx-loadgen\"})",
          "legendFormat": "loadgen",
          "range": true,
          "refId": "loadgen"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(rx_message_publish_total{queue=\"rx.commands\"}[$__rate_interval]))",
          "legendFormat": "command publish",
          "range": true,
          "refId": "commandPublish"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(rx_queue_messages_total{queue=\"rx.commands\",direction=\"consume\"}[$__rate_interval]))",
          "legendFormat": "command consume",
          "range": true,
          "refId": "commandConsume"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(rx_message_publish_total{queue=\"rx.events\"}[$__rate_interval]))",
          "legendFormat": "event publish",
          "range": true,
          "refId": "eventPublish"
        },
        {
          "editorMode": "code",
          "expr": "sum(rate(rx_queue_messages_total{queue=\"rx.events\",direction=\"consume\"}[$__rate_interval]))",
          "legendFormat": "event consume",
          "range": true,
          "refId": "eventConsume"
        }
      ],
      "title": "Executive Service Flow",
      "type": "neildengg-grafmaid-panel"
