      "id": 1,
      "options": {
        "content": "flowchart LR\n  api[\"API Gateway<br/>value: ${__data.apiHealth:display}<br/>fill: ${__data.apiHealth:color}\"]\n  worker[\"Sync Worker<br/>value: ${__data.workerHealth:display}<br/>fill: ${__data.workerHealth:color}\"]\n  projection[\"Projection<br/>value: ${__data.projectionHealth:display}<br/>fill: ${__data.projectionHealth:color}\"]\n  ui[\"UI<br/>value: ${__data.uiHealth:display}<br/>fill: ${__data.uiHealth:color}\"]\n\n  ui --> api --> worker --> projection\n\n  style api fill:${__data.apiHealth:color},color:#fff,stroke:#263238,stroke-width:2px\n  style worker fill:${__data.workerHealth:color},color:#fff,stroke:#263238,stroke-width:2px\n  style projection fill:${__data.projectionHealth:color},color:#fff,stroke:#263238,stroke-width:2px\n  style ui fill:${__data.uiHealth:color},color:#fff,stroke:#263238,stroke-width:2px",
        "escapeSpecialChars": false,
        "maxDataRows": 100
      },
      "pluginVersion": "11.1.4",
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(rx_component_health_percent{component=\"api-gateway\"})",
          "legendFormat": "apiHealth",
          "range": true,
          "refId": "apiHealth"
        },
        {
          "editorMode": "code",
          "expr": "max(rx_component_health_percent{component=\"legacy-sync-worker\"})",
          "legendFormat": "workerHealth",
          "range": true,
          "refId": "workerHealth"
        },
        {
          "editorMode": "code",
          "expr": "max(rx_component_health_percent{component=\"read-model-projection\"})",
          "legendFormat": "projectionHealth",
          "range": true,
          "refId": "projectionHealth"
        },
        {
          "editorMode": "code",
          "expr": "max(rx_component_health_percent{component=\"rx-ui\"})",
          "legendFormat": "uiHealth",
          "range": true,
          "refId": "uiHealth"
        }
      ],
      "title": "Grafmaid Query Color Probe",
