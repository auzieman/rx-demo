          "refId": "eventConsume"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(rx_process_duration_ms_bucket{queue=\"rx.events\"}[$__rate_interval]))) or vector(0)",
          "legendFormat": "event process p95",
          "range": true,
          "refId": "eventP95"
