        },
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "definition": "query_result(topk(25, sum by (rx_id) (count_over_time({service_name=~\"rx/.+\"} |= \"CloudEvent audit\" | regexp \"rxId=(?P<rx_id>RX[-A-Z0-9]+)\" [$__range]))))",
        "hide": 0,
        "includeAll": true,
        "label": "Transaction",
        "multi": false,
        "name": "rx_id",
        "options": [],
        "query": "query_result(topk(25, sum by (rx_id) (count_over_time({service_name=~\"rx/.+\"} |= \"CloudEvent audit\" | regexp \"rxId=(?P<rx_id>RX[-A-Z0-9]+)\" [$__range]))))",
        "refresh": 2,
        "regex": "/rx_id=\"([^\"]+)\"/",
        "skipUrlSync": false,
        "sort": 3,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": {
          "selected": true,
          "text": "All",
          "value": ".*"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Outcome Filter",
        "multi": false,
        "name": "event_filter",
        "options": [
          {
            "selected": true,
            "text": "All",
            "value": ".*"
          },
          {
            "selected": false,
            "text": "Failed",
            "value": "outcome=failure|result=error|error|failed"
          },
          {
            "selected": false,
            "text": "Successful",
            "value": "outcome=success|result=ok|ApproveQueued|RefillQueued"
          }
        ],
        "query": "All : .*, Failed : outcome=failure|result=error|error|failed, Successful : outcome=success|result=ok|ApproveQueued|RefillQueued",
        "skipUrlSync": false,
        "type": "custom"
      }
