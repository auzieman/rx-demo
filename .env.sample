# Copy to .env for local runs. This sample is intentionally secret-free.

COMPOSE_PROJECT_NAME=rx-demo

RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=
SA_PASSWORD=

Otel__Environment=lab
OTEL_COLLECTOR_SERVICE=otel-collector

# Use the existing lab Loki service by default. Override to http://loki:3100/loki/api/v1/push
# when running the optional local-observability compose profile.
LOKI_ENDPOINT=http://loki.monitoring.local:3100/loki/api/v1/push
TEMPO_ENDPOINT=http://tempo.monitoring.local:4318
